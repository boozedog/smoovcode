{
  "$schema": "https://raw.githubusercontent.com/oxc-project/oxc/main/npm/oxlint/configuration_schema.json",
  "plugins": ["import"],
  "rules": {
    "import/no-namespace": "error",
    "no-restricted-imports": [
      "error",
      {
        "paths": [
          {
            "name": "react",
            "importNames": ["default", "*", "useEffect", "useLayoutEffect", "useInsertionEffect"],
            "message": "React default/namespace imports and useEffect/useLayoutEffect/useInsertionEffect are banned. Import React APIs by name; use useMountEffect from @smoovcode/ui-react for mount-only effects. See CLAUDE.md > React rules."
          }
        ]
      }
    ]
  },
  "overrides": [
    {
      "files": ["packages/ui-react/src/use-mount-effect.ts"],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ]
}
