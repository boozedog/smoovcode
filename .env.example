# Provider: openai (default) or fireworks
SMOOV_PROVIDER=fireworks

# Fireworks can use FIREWORKS_API_KEY directly; SMOOV_API_KEY also works.
FIREWORKS_API_KEY=
SMOOV_API_KEY=
SMOOV_MODEL=accounts/fireworks/routers/kimi-k2p5-turbo
SMOOV_BACKEND=local

# Optional Fireworks thinking/reasoning controls.
# SMOOV_FIREWORKS_THINKING=enabled
# SMOOV_FIREWORKS_THINKING_BUDGET_TOKENS=4096
# SMOOV_FIREWORKS_REASONING_HISTORY=interleaved

# Zero Data Retention. When true, sets store:false on Responses API requests
# so prior items are sent inline (otherwise item_reference IDs resolve to
# nothing on ZDR providers and the model loops re-calling tools).
# Default: auto — true for non-OpenAI base URLs, false for api.openai.com.
# SMOOV_ZDR=true
